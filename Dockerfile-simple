# Build stage for frontend
FROM node:18-alpine AS frontend-builder
WORKDIR /app/client
COPY client/package-simple.json package.json
COPY client/vite-simple.config.js vite.config.js
COPY client/index-simple.html index.html
RUN npm install
COPY client/src ./src
RUN npm run build

# Build stage for backend
FROM node:18-alpine AS backend-builder
WORKDIR /app/api
COPY api/package-simple.json package.json
RUN npm install
COPY api/server/simple-server.js ./server/

# Production stage
FROM node:18-alpine
WORKDIR /app

# Copy backend
COPY --from=backend-builder /app/api ./api

# Copy frontend build
COPY --from=frontend-builder /app/client/dist ./client/dist

# Create .env file template
RUN echo "# Gemini API Keys (comma-separated)\nALL_GEMINI_API_KEYS=your_api_key_here\n\n# Server Port\nPORT=3080" > .env

# Expose port
EXPOSE 3080

# Start the server
CMD ["node", "api/server/simple-server.js"]